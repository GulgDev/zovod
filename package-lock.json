{
  "name": "zovod",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "zovod",
      "workspaces": [
        "packages/*"
      ],
      "devDependencies": {
        "@tsconfig/recommended": "^1.0.13",
        "typescript": "^6.0.3"
      }
    },
    "node_modules/@tsconfig/recommended": {
      "version": "1.0.13",
      "dev": true,
      "license": "MIT"
    },
    "node_modules/@zovod/engine": {
      "resolved": "packages/engine",
      "link": true
    },
    "node_modules/typescript": {
      "version": "6.0.3",
      "dev": true,
      "license": "Apache-2.0",
      "bin": {
        "tsc": "bin/tsc",
        "tsserver": "bin/tsserver"
      },
      "engines": {
        "node": ">=14.17"
      }
    },
    "packages/engine": {
      "name": "@zovod/engine",
      "version": "0.0.1"
    }
  }
}
