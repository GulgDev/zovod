{
  "compilerOptions": {
    "module": "esnext",
    "moduleResolution": "bundler",
    "verbatimModuleSyntax": true,
    "target": "esnext",
    "composite": true,
    "incremental": true,
    "declaration": true,

    // code style
    "noImplicitOverride": true,

    // improve build performance
    "skipLibCheck": true
  }
}
